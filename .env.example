# Answerbase environment variables.
# Copy to .env.local and fill in real values. Never commit .env.local.

# --- Supabase (Settings → API in the Supabase dashboard) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenRouter (covers both chat and embeddings) ---
OPENROUTER_API_KEY=

# --- Stripe (test mode) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRICE_PRO=

# --- App ---
# Local: http://localhost:3000 — Production: your Vercel URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
